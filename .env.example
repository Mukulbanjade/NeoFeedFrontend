# Copy to .env.local for local dev (optional).
# In Vercel and Lovable, add the same variable under Environment / Build settings:
# VITE_API_URL=https://neofeed.onrender.com
#
# If unset, the app uses https://neofeed.onrender.com.
# Users can still override in Settings (stored in localStorage).

VITE_API_URL=https://neofeed.onrender.com
